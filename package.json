{
  "name": "flowdesk",
  "version": "1.0.0",
  "description": "Bot de ticket premium para Discord com Components V2, logs e transcript HTML.",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "bot": "powershell -ExecutionPolicy Bypass -File ./scripts/bot-publish.ps1",
    "dev": "node --watch src/main.js",
    "deploy:commands": "node src/deploy-commands.js",
    "login": "node scripts/login.js",
    "logout": "node scripts/logout.js",
    "site:dev": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "now": "node scripts/now.js",
    "puxar": "git pull --rebase --autostash"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@napi-rs/canvas": "^0.1.80",
    "@supabase/supabase-js": "^2.99.2",
    "discord-html-transcripts": "^3.2.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "git": "^0.1.5",
    "nodemailer": "^8.0.7",
    "tweetnacl": "^1.0.3"
  }
}
